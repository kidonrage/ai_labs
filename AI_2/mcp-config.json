{
  "mcpServers": {
    "weather": {
      "command": "python3",
      "args": ["./weather_mcp/mock-weather-mcp-server/main.py"],
      "toolFilter": {
        "tools": ["get_current_temperature"]
      }
    },
    "task_runtime": {
      "command": "python3",
      "args": ["./task_runtime/task_mcp_server.py", "--transport", "stdio"],
      "toolFilter": {
        "tools": ["schedule_task", "get_task_runs_report"]
      }
    }
  }
}
