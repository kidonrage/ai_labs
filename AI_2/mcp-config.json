{
  "mcpServers": {
    "weather": {
      "command": "python3",
      "args": ["./weather_mcp/mock-weather-mcp-server/main.py"],
      "toolFilter": {
        "tools": ["get_current_temperature"]
      }
    },
    "task_runtime": {
      "command": "python3",
      "args": ["./periodic_summary_mcp/main.py"],
      "toolFilter": {
        "tools": ["enable_periodic_summary", "get_periodic_summary"]
      }
    }
  }
}
