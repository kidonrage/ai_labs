{
  "mcpServers": {
    "save_to_file": {
      "command": "python3",
      "args": ["./save_server.py"],
      "toolFilter": {
        "tools": ["save_to_file"]
      }
    },
    "search": {
      "command": "python3",
      "args": ["./search_server.py"],
      "toolFilter": {
        "tools": ["search"]
      }
    },
    "get_git_branch": {
      "command": "python3",
      "args": ["./git_branch_server.py"],
      "toolFilter": {
        "tools": ["get_git_branch"]
      }
    },
    "summarize": {
      "command": "python3",
      "args": ["./summarize_server.py"],
      "toolFilter": {
        "tools": ["summarize"]
      }
    }
  }
}
